# Instalátor vytváří .ops.env atomicky (běžný soubor, vlastník=ops uživatel, mode 600).
# Skripty přijímají jen tento allowlist KEY=VALUE a soubor nikdy nespouštějí jako shell.
VYSTAVENO_BASE_URL=https://vystaveno.cz
VYSTAVENO_BACKUP_RETENTION_DAYS=14
VYSTAVENO_MAX_BACKUP_AGE_SECONDS=108000
VYSTAVENO_MAX_RESTORE_CHECK_AGE_SECONDS=691200
VYSTAVENO_MIN_DISK_FREE_PERCENT=10

# Volitelné: Healthchecks.io nebo kompatibilní ping URL. URL obsahuje tajný token.
VYSTAVENO_MONITOR_PING_URL=

# Volitelné: připojený vzdálený disk / mount. Adresář na stejném VPS není off-site záloha.
VYSTAVENO_BACKUP_MIRROR_DIR=
