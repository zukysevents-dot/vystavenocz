# Veřejné proměnné frontendu (Vite). NIKDY sem nedávej serverové secrety.
# Zkopíruj do .env a vyplň podle potřeby.

# Základ URL API (vystaveno-api) včetně prefixu verze, např. http://localhost:5080/api/v1
# Prázdné = mock datová vrstva přes localStorage (výchozí pro MVP / e2e testy).
VITE_API_URL=

# Sledovani chyb pres Sentry (volitelne)
VITE_SENTRY_DSN=
