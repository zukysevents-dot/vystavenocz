# Veřejné proměnné frontendu (Vite). NIKDY sem nedávej serverové secrety.
# Zkopíruj do .env a vyplň podle potřeby.

# Základ URL API (vystaveno-api) včetně prefixu verze, např. http://localhost:5080/api/v1
# Prázdné = mock datová vrstva přes localStorage (výchozí pro MVP / e2e testy).
VITE_API_URL=

# Sledovani chyb pres Sentry (volitelne)
VITE_SENTRY_DSN=

# E2E audit (playwright.audit.config.ts) — přihlašovací údaje demo účtu.
# Hodnoty NIKDY necommituj; nastav lokálně v shellu nebo v necommitovaném .env.
E2E_DEMO_EMAIL=
E2E_DEMO_PASSWORD=
# Base URL běžícího frontendu v API režimu (default http://localhost:5173)
E2E_BASE_URL=

# Persona E2E (playwright.personas.config.ts) — heslo persona účtů zakládaných setupem.
# Lokálně dej do gitignorovaného .env.e2e; NIKDY necommitovat skutečné hodnoty.
E2E_PERSONA_PASSWORD=
E2E_API_URL=
